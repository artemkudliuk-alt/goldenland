# ==============================================================================
# Golden Land Project Environment Variables
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# OpenAI API Key (Required for gpt-image, ima2, and other GPT-based design skills)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot Token & Chat ID (For CRM notification integrations)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Next.js Server Port (Optional)
PORT=3000

# Email Lead Capture (Nodemailer SMTP configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_or_app_password_here
EMAIL_FROM="Golden Land Property" <noreply@goldenlandproperty.com.ua>
EMAIL_TO=info@goldenlandproperty.com.ua

# Admin CRM access (server-side gate for /admin and /api/admin/*)
# ADMIN_PASSWORD: the passcode typed on the /admin login screen
# ADMIN_SESSION_SECRET: random 32+ byte hex string, never share (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_PASSWORD=change_me_to_a_strong_passphrase
ADMIN_SESSION_SECRET=generate_a_long_random_hex_string_here

# Where lead data is stored (for the admin CRM). Defaults to the project root.
# On a container/VPS deploy, point this at a mounted PERSISTENT volume (e.g. /data)
# so captured leads survive redeploys. Not needed for local dev.
# LEADS_DATA_DIR=/data
